# 股票量化系统配置示例
# 复制此文件为 config.yaml 并修改配置

# 股票配置
stocks:
  - 601728  # 中国电信
  - 600938  # 中国海油
  # 添加更多股票代码（上海6开头，深圳0或3开头）
  # - 000001  # 平安银行
  # - 300750  # 宁德时代

# 数据源配置
data_source:
  type: web_crawler  # 使用网页爬虫获取真实数据，系统不再依赖akshare
  # 如果需要tushare，请设置token
  # tushare_token: "your_tushare_token_here"
  # 系统只使用真实数据，拒绝模拟数据，确保投资决策准确性
  # 当akshare失败时，系统会自动尝试使用网页爬虫获取真实数据

# 邮件通知配置
email:
  smtp_server: smtp.yeah.net  # yeah.net邮箱SMTP服务器，其他邮箱：smtp.163.com, smtp.qq.com
  smtp_port: 587  # 使用TLS的端口，QQ邮箱用465或587
  sender_email: ""  # 发送邮箱，通过环境变量EMAIL_SENDER设置
  sender_password: ""  # 邮箱密码或授权码，通过环境变量EMAIL_PASSWORD设置
  receiver_email: ""  # 接收邮箱，通过环境变量EMAIL_RECEIVER设置
  enable_tls: true  # 启用TLS加密

# LLM API配置（可选）
llm:
  api_type: deepseek  # 使用DeepSeek API，可选：openai, deepseek
  api_key: ""  # 请在此处填写API密钥，建议使用环境变量
  base_url: "https://api.deepseek.com/v1"  # DeepSeek API地址
  model: "deepseek-chat"  # 使用的模型

# 系统运行配置
scheduler:
  run_time: "16:00"  # 主任务运行时间
  cache_bypass_cutoff: "15:55"
  timezone: "Asia/Shanghai"
  run_on_startup: false
  # 简报任务：每个交易日特定时间触发轻量报告
  brief_reports:
    - id: morning_snapshot
      run_time: "09:50"
      label: "早盘简报"
      enabled: true
      skip_weekends: true

# 投资组合策略（可选，不配置使用默认MA60锚点择时）
