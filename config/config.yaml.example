# 股票量化系统配置文件示例
# 复制为 config/config.yaml 并修改

# ── 公告 ──
announcements:
  days: 7
  dividend_days: 420
  enable: true
  include_in_email: true
  enable_content_fetching: true
  enable_llm_extraction: true
  max_llm_calls_per_run: 30
  max_pdf_size_mb: 10

# ── 财报 ──
financial_reports:
  enable: false
  auto_enable: true
  conditional_enable: true
  force_analyze: false
  max_stocks_per_run: 2
  max_force_stocks: 2
  max_llm_calls_per_run: 80
  reports_per_stock: 3
  conditional_days: 30

# ── 数据源 ──
data_source:
  type: web_crawler
  primary: web_crawler
  secondary: baostock
  etf_force_web_crawler: true
  fallback_to_web_crawler: true

# ── 邮件 (填入你的 SMTP 信息) ──
email:
  enable_ssl: true
  enable_tls: false
  smtp_port: 465
  smtp_server: smtp.your-email-provider.com   # 例如 smtp.gmail.com / smtp.yeah.net

# ── LLM (DeepSeek) ──
llm:
  api_type: deepseek
  base_url: https://api.deepseek.com/v1
  model: deepseek-chat
  enable_fundamental_analysis: false

# ── 日志 ──
logging:
  file: ./logs/quant_system.log
  format: '%(asctime)s - %(name)s - %(levelname)s - %(message)s'
  level: INFO

# ── 调度 ──
scheduler:
  run_time: '16:00'
  cache_bypass_cutoff: '15:55'
  timezone: Asia/Shanghai
  brief_reports:
    - id: morning_snapshot
      run_time: '09:50'
      label: 早盘简报
      stocks: []   # 填入你的股票代码列表

# ── 监控标的 ──
stocks: []           # 填入你的股票代码，例如 [601728, 000001, VOO]

# ── 策略搜索优化器 ──
optimizer:
  enable: true
  drawdown_limit: -30
  output_dir: ./data/optimizer

# ── 历史数据缓存 ──
historical_cache:
  enable: true
  historical_cache_days: 30
  force_update_interval_days: 30
  check_dividend_interval_days: 7
  historical_lookback_days: 730
  enable_historical_cache: true

# ── 健康检查服务器 ──
health_server:
  enabled: true
  host: 0.0.0.0
  port: 1933
  ssl: false                            # 是否启用 HTTPS (需自签名证书)
  cert_file: cert.pem                   # SSL 证书路径 (ssl=true 时需提供)
  key_file: key.pem                     # SSL 私钥路径 (ssl=true 时需提供)
  ip_detect_url: https://ifconfig.me    # 公网 IP 检测服务 (报告链接用)

# ── 多层警报系统 ──
alerts:
  config_path: "./config/alerts.yaml"
  enabled: true
