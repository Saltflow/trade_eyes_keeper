# ================================================================
# Stock Quant System — 环境变量配置
# ================================================================
# 1. 复制此文件为 config/.env:  cp config/.env.example config/.env
# 2. 按下方说明逐个填写
# 3. 首次部署参考: docs/guide/setup.md
# ================================================================

# ============================================================
# 邮箱 — 用于发送日报/告警/简报 (必填)
# ============================================================
# 推荐 yeah.net 邮箱: 登录 → 设置 → POP3/SMTP/IMAP → 开启 SMTP → 获取授权码
# 其他邮箱可参考各服务商的 SMTP 文档
EMAIL_SENDER=your_email@yeah.net
EMAIL_PASSWORD=your_authorization_code    # 不是登录密码, 是 SMTP 授权码
EMAIL_RECEIVER=receiver_email@example.com

# ============================================================
# DeepSeek API — LLM 股息提取 (可选)
# ============================================================
# 注册 https://platform.deepseek.com → 获取 API Key
# 不填则跳过 LLM 股息提取, 不影响核心监控功能
DEEPSEEK_API_KEY=sk-your_key_here

# ============================================================
# 飞书 Bot — 群消息推送 (可选)
# ============================================================
# 方式一：群 Webhook Bot（只发不收）
# 创建方式：飞书群 → 设置 → 群机器人 → 添加自定义机器人 → 复制 Webhook URL
# ============================================================
FEISHU_WEBHOOK_URL=

# ============================================================
# 飞书开放平台应用 Bot — 交互式命令 (可选，支持收发消息)
# ============================================================
# 创建方式：飞书开发者后台 → 创建企业自建应用 → 获取凭证
# 详细步骤参考：docs/guide/feishu_telegram_setup.md
# ============================================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# ============================================================
# Telegram Bot — 消息推送 (可选)
# ============================================================
# 创建方式：Telegram 搜索 @BotFather → /newbot → 获取 Token
# 获取 Chat ID：给 Bot 发消息后，浏览器访问
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# 详细步骤参考：docs/guide/feishu_telegram_setup.md
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# 部署服务器 — 用于 ci_cd_deploy.py 推送代码到服务器 (部署时必填)
# ============================================================

# 服务器公网 IP 或域名
# 获取方式: 登录你的服务器, 执行 curl ifconfig.me
DEPLOY_HOST=0.0.0.0

# SSH 登录用户名 (通常为 root)
DEPLOY_SSH_USER=root

# SSH 私钥路径 (相对于项目根目录, 或绝对路径)
# 生成方式: ssh-keygen -t ed25519 -f deploy_key -N ""
# 然后将 deploy_key.pub 追加到服务器: ~/.ssh/authorized_keys
# 本地执行: ssh-copy-id -i deploy_key.pub DEPLOY_SSH_USER@DEPLOY_HOST
DEPLOY_SSH_KEY=deploy_key

# Git push 目标 URL — 格式: ssh://用户名@主机/服务器项目绝对路径
# 只需修改 主机IP 和 路径 两个地方
DEPLOY_SSH_REMOTE=ssh://root@0.0.0.0/root/trade_eyes_keeper

# 服务器上项目目录 — 必须与 DEPLOY_SSH_REMOTE 的路径一致
DEPLOY_REMOTE_DIR=/root/trade_eyes_keeper

# ============================================================
# 调试开关 (可选)
# ============================================================

# 跳过邮件发送 (测试用)
SKIP_EMAIL=false

# 部署前清理 30 天以上旧日志/邮件存档
CLEAN_BEFORE_DEPLOY=true

# ============================================================
# 以下通常无需修改
# ============================================================

# Tushare Token (当前未使用 — 系统使用网页爬虫获取数据)
TUSHARE_TOKEN=

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
