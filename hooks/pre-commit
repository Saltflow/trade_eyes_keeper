#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Git pre-commit hook
检查: ruff lint + import smoke + session safety tests
"""

import os
import sys
import subprocess
import logging

logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
logger = logging.getLogger("pre-commit")


def run(cmd, name, timeout=60):
    """Run a command, return True on success"""
    logger.info("--- %s ---", name)
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        if result.returncode != 0:
            logger.error("FAIL: %s\n%s", name, result.stderr[:500])
            return False
        logger.info("PASS: %s", name)
        return True
    except subprocess.TimeoutExpired:
        logger.error("TIMEOUT: %s", name)
        return False
    except Exception as e:
        logger.error("ERROR: %s — %s", name, e)
        return False


def main():
    project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    python = sys.executable

    # 1. ruff check
    if not run([python, "-m", "ruff", "check", "src/", "--select", "F,E"],
               "ruff check", timeout=30):
        sys.exit(1)

    # 2. import smoke
    if not run([python, "-c",
        "import importlib;"
        "modules=['src.analysis.backtest_config','src.analysis.indicator_library',"
        "'src.analysis.strategy_optimizer','src.analysis.signal_scanner',"
        "'src.health_server.core.global_instances'];"
        "[importlib.import_module(m) for m in modules];"
        "print('OK')"
    ], "import smoke", timeout=15):
        sys.exit(1)

    # 3. session safety tests
    safety = os.path.join(project_root, "tests", "validation", "test_session_safety.py")
    if os.path.exists(safety):
        if not run([python, "-m", "pytest", safety, "-q", "--tb=short"],
                   "session safety", timeout=30):
            sys.exit(1)

    logger.info("All pre-commit checks passed")
    sys.exit(0)


if __name__ == "__main__":
    main()
